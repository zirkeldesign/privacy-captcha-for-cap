{
  "name": "zirkeldesign/privacy-captcha-for-cap",
  "description": "Privacy-friendly spam protection for WordPress comments, login, registration, WooCommerce, and Gravity Forms, powered by your own Cap (trycap.dev) server.",
  "license": "GPL-2.0-or-later",
  "type": "wordpress-plugin",
  "keywords": [
    "wordpress",
    "captcha",
    "cap",
    "trycap",
    "spam",
    "proof-of-work",
    "comments",
    "login",
    "woocommerce",
    "gravity-forms"
  ],
  "authors": [
    {
      "name": "zirkel.design",
      "email": "hello@zirkel.design",
      "homepage": "https://zirkel.design"
    },
    {
      "name": "Daniel Sturm",
      "email": "d.sturm@zirkeldesign.de",
      "homepage": "https://zirkel.design"
    }
  ],
  "homepage": "https://github.com/zirkeldesign/privacy-captcha-for-cap",
  "support": {
    "issues": "https://github.com/zirkeldesign/privacy-captcha-for-cap/issues",
    "source": "https://github.com/zirkeldesign/privacy-captcha-for-cap"
  },
  "require": {
    "php": "^8.3"
  },
  "require-dev": {
    "laravel/pint": "^1.27",
    "pestphp/pest": "^3.0",
    "php-stubs/gravity-forms-stubs": "^2.8",
    "php-stubs/wordpress-stubs": "^6.7",
    "phpstan/phpstan": "^2.0",
    "szepeviktor/phpstan-wordpress": "^2.0"
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "autoload": {
    "psr-4": {
      "ZirkelDesign\\CapCaptcha\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ZirkelDesign\\CapCaptcha\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    },
    "platform": {
      "php": "8.3"
    },
    "sort-packages": true
  },
  "scripts": {
    "format": "pint",
    "format:test": "pint --test",
    "phpstan": "phpstan analyse --memory-limit=1G",
    "test": "pest",
    "plugin-check": [
      "@php -r \"echo '🔍 Running Plugin Check...\\n';\"",
      "wp plugin check privacy-captcha-for-cap 2>/dev/null | grep -c '\\\"type\\\":\\\"ERROR\\\"' | xargs -I {} sh -c 'if [ {} -eq 0 ]; then echo \"✅ No ERRORs found\"; else echo \"❌ {} ERROR(s) found — run wp plugin check privacy-captcha-for-cap for details\" && exit 1; fi'"
    ],
    "dist": [
      "@php -r \"echo '🔨 Building distribution archive...\\n';\"",
      "@putenv COMPOSER_DISCARD_CHANGES=true",
      "composer install --no-dev --optimize-autoloader --quiet",
      "mkdir -p dist",
      "@php get-version.php > .version",
      "wp dist-archive . dist/privacy-captcha-for-cap-$(cat .version).zip --plugin-dirname=privacy-captcha-for-cap",
      "composer install --quiet",
      "@php -r \"echo '✅ Distribution archive created: dist/privacy-captcha-for-cap-' . trim(file_get_contents('.version')) . '.zip\\n'; unlink('.version');\""
    ]
  }
}
