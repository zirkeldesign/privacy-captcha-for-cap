msgid "Defined via CAP_CAPTCHA_SECRET_KEY in wp-config.php — value here is read-only."
msgstr "Definiert via CAP_CAPTCHA_SECRET_KEY in wp-config.php — Wert hier ist schreibgeschützt."

#: src/Settings.php:323
msgid "Defined via CAP_CAPTCHA_ADMIN_API_KEY in wp-config.php — value here is read-only."
msgstr "Definiert via CAP_CAPTCHA_ADMIN_API_KEY in wp-config.php — Wert hier ist schreibgeschützt."

#: src/Settings.php:257
msgid "Defined via CAP_CAPTCHA_ENDPOINT in wp-config.php — value here is read-only."
msgstr "Definiert via CAP_CAPTCHA_ENDPOINT in wp-config.php — Wert hier ist schreibgeschützt."

#: src/Settings.php:279
msgid "Defined via CAP_CAPTCHA_SITE_KEY in wp-config.php — value here is read-only."
msgstr "Definiert via CAP_CAPTCHA_SITE_KEY in wp-config.php — Wert hier ist schreibgeschützt."

