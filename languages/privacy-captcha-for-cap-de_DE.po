msgid "Cap server — load from your endpoint at /assets/cap_wasm_bg.wasm"
msgstr "Cap-Server — wird von deinem Endpunkt unter /assets/cap_wasm_bg.wasm geladen"

#: src/Settings.php:371
msgid "jsdelivr CDN — fastest globally, but leaks visitor IPs to a third party"
msgstr "jsdelivr CDN — global am schnellsten, gibt Besucher-IPs aber an einen Dritten weiter"

