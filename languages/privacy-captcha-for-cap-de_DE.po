#: src/Integration/Comments.php:44
#: src/Settings.php:666
msgid "Comments"
msgstr "Kommentare"

#: src/Settings.php:667
msgid "Protects the default WordPress comment form."
msgstr "Schützt das Standard-Kommentarformular von WordPress."

#: src/Integration/Login.php:73
#: src/Settings.php:671
msgid "Login"
msgstr "Anmeldung"

#: src/Settings.php:672
msgid "Protects wp-login.php and any front-end login form using login_form."
msgstr "Schützt wp-login.php sowie Frontend-Anmeldeformulare, die login_form verwenden."

#: src/Integration/Registration.php:51
#: src/Settings.php:676
msgid "Registration"
msgstr "Registrierung"

#: src/Settings.php:677
msgid "Protects the WordPress user registration form."
msgstr "Schützt das WordPress-Registrierungsformular."

#: src/Integration/WooCommerce.php:43
#: src/Settings.php:681
msgid "WooCommerce checkout"
msgstr "WooCommerce-Kasse"

#: src/Settings.php:682
msgid "Protects the WooCommerce checkout form."
msgstr "Schützt das WooCommerce-Kassenformular."

#: src/Settings.php:420
msgid "Admin notices"
msgstr "Admin-Hinweise"

#: src/Settings.php:424
msgid "Warn site admins inline when an enabled integration is not configured"
msgstr "Admins inline warnen, wenn eine aktivierte Integration nicht konfiguriert ist"

#: src/Settings.php:426
msgid "Only users with manage_options ever see these notices — anonymous visitors get nothing rendered."
msgstr "Nur Benutzer mit manage_options sehen diese Hinweise — anonymen Besuchern wird nichts angezeigt."

#: src/Settings.php:310
msgid "Admin API key"
msgstr "Admin-API-Schlüssel"

#: src/Settings.php:325
msgid "Optional. Issue a dedicated key under Settings → API Keys in your Cap server and paste it here. Used for the Status panel below. Define CAP_CAPTCHA_ADMIN_API_KEY in wp-config.php to override."
msgstr "Optional. Erstelle einen dedizierten Schlüssel unter Einstellungen → API Keys auf deinem Cap-Server und füge ihn hier ein. Wird für die Status-Anzeige unten verwendet. Optional in wp-config.php via CAP_CAPTCHA_ADMIN_API_KEY überschreiben."

#: src/Settings.php:446
msgid "Status"
msgstr "Status"

#: src/Settings.php:450
msgid "Could not fetch status from the Cap server. Check the Endpoint, Site key, and Admin API key."
msgstr "Status vom Cap-Server konnte nicht geladen werden. Bitte Endpunkt, Site-Schlüssel und Admin-API-Schlüssel prüfen."

#: src/Settings.php:482
msgid "Site"
msgstr "Site"

#: src/Settings.php:516
msgid "Difficulty"
msgstr "Schwierigkeit"

