msgstr "Programmatisch — löst sich unbemerkt im Hintergrund (keine Nutzerinteraktion)"

#: src/Settings.php:350
msgid "Per-form integrations can override this default."
msgstr "Einzelne Integrationen können diesen Standard überschreiben."

#: src/Settings.php:355
msgid "Privacy"
msgstr "Datenschutz"

#: src/Settings.php:358
msgid "WASM source"
msgstr "WASM-Quelle"

