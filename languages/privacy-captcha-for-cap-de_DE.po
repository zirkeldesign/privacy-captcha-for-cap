msgid "Integrations"
msgstr "Integrationen"

#: src/Settings.php:399
msgid "Plugin not active"
msgstr "Plugin nicht aktiv"

#: src/Settings.php:407
msgid "Behavior"
msgstr "Verhalten"

#: src/Settings.php:410
msgid "Fail-open mode"
msgstr "Fail-Open-Modus"

#: src/Settings.php:414
msgid "Let submissions through when the Cap server is unreachable"
msgstr "Sende-Vorgänge durchlassen, wenn der Cap-Server nicht erreichbar ist"

#: src/Settings.php:416
msgid "Off by default. Enable only if temporary Cap outages must not block legitimate users (logins, checkouts)."
msgstr "Standardmäßig aus. Nur aktivieren, wenn vorübergehende Cap-Ausfälle nicht zu blockierten Nutzern führen dürfen (Logins, Checkouts)."

