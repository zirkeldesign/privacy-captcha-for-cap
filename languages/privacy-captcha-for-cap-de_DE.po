msgstr "%1$d Challenges · %2$d-Byte-Salt"

#: src/Settings.php:534
msgid "Refresh now"
msgstr "Jetzt aktualisieren"

#: src/Settings.php:535
msgid "Status is cached for 5 minutes."
msgstr "Status wird 5 Minuten zwischengespeichert."

#: src/Settings.php:589
msgid "Hourly solves chart"
msgstr "Stundenweise Lösungen"

