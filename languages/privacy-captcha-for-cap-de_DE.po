msgstr "Cap-Server"

#: src/Settings.php:303
msgid "Secret key used to call /siteverify. Define CAP_CAPTCHA_SECRET_KEY in wp-config.php to override."
msgstr "Geheimer Schlüssel für den /siteverify-Aufruf. Optional in wp-config.php via CAP_CAPTCHA_SECRET_KEY überschreiben."

#: src/Settings.php:340
msgid "Display"
msgstr "Darstellung"

#: src/Settings.php:343
msgid "Default display mode"
msgstr "Standard-Darstellung"

#: src/Settings.php:346
msgid "Inline — widget visible in the form"
msgstr "Inline — Widget sichtbar im Formular"

